{
  "compilerOptions": {
    "target":            "ESNext",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ESNext", "DOM"],
    "jsx":               "preserve",
    "strict":            true,
    "skipLibCheck":      true,
    "declaration":       true,
    "declarationDir":    "./dist"
  },
  "include":  ["src/**/*"],
  "exclude":  ["dist", "node_modules"]
}
