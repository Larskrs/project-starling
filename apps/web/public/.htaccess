<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Proxy /api and /socket to the Node backend on cino.no
  RewriteRule ^api(/.*)?$    https://cino.no/api$1    [P,L]
  RewriteRule ^socket(/.*)?$ wss://cino.no/socket$1   [P,L]

  # Skip real files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Client-side routes → index.html
  RewriteRule ^ index.html [L]
</IfModule>
