{
  "name": "project-starling",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "npm run -w @starling/db db:generate",
    "db:migrate": "npm run -w @starling/db db:migrate",
    "db:push": "npm run -w @starling/db db:push",
    "db:studio": "npm run -w @starling/db db:studio",
    "set-role":  "npm run -w @starling/db set-role --"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "ws": "8.21.0",
    "esbuild": "0.25.5",
    "engine.io": {
      "ws": "8.21.0"
    },
    "engine.io-client": {
      "ws": "8.21.0"
    },
    "socket.io-adapter": {
      "ws": "8.21.0"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
